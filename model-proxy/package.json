{
  "name": "noobot-model-proxy",
  "version": "4.0.4",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "test": "node --test __tests__/*.test.js",
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "pm2:start": "PM2_HOME=../.pm2 npx pm2 start src/index.js --name noobot-model-proxy",
    "pm2:restart": "PM2_HOME=../.pm2 npx pm2 restart noobot-model-proxy",
    "pm2:stop": "PM2_HOME=../.pm2 npx pm2 stop noobot-model-proxy",
    "pm2:delete": "PM2_HOME=../.pm2 npx pm2 delete noobot-model-proxy",
    "pm2:logs": "PM2_HOME=../.pm2 npx pm2 logs noobot-model-proxy",
    "pm2:list": "PM2_HOME=../.pm2 npx pm2 list"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "@noobot/sanitize": "file:../sanitize",
    "http-proxy": "^1.18.1"
  }
}
