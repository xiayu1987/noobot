{
  "workspaceRoot": "../workspace",
  "workspaceTemplatePath": "../user-template/default-user",
  "memoryMaxItems": 50,
  "maxToolLoopTurns": 30,
  "session": {
    "recentMessageLimit": 20,
    "useLastRunningTaskRange": true,
    "useLastCompletedTaskRange": true
  },
  "tools": {
    "web_search_to_data": {
      "enabled": false,
      "processMode": "direct"
    },
    "web_to_data": {
      "enabled": true,
      "processMode": "direct"
    },
    "doc_to_data": {
      "enabled": true
    },
    "process_content_task": {
      "enabled": true,
      "maxToolLoopTurns": 2
    }
  },
  "script": {
    "sandboxMode": true,
    "sandboxProvider": {
      "default": "docker",
      "docker": {
        "dockerContainerScope": "global",
        "dockerContainerName": "noobot-script-sandbox",
        "dockerImage": "node:20"
      },
      "bubblewrap": {},
      "firejail": {}
    }
  },
  "async": {
    "waitTimeoutMs": 120000,
    "maxSubAgentDepth": 3
  },
  "scriptTimeoutMs": 120000,
  "streaming": true,
  "superAdmin": {
    "userId": "admin",
    "connectCode": "change-your-connect-code"
  }
}
