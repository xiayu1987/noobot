{
  "workspace_root": "../workspace",
  "workspace_template_path": "../user-template/default-user",
  "default_provider": "qwen3_6_plus_2026_04_02",
  "memory_max_items": 50,
  "max_tool_loop_turns": 200,
  "session": {
    "recent_message_limit": 15,
    "use_last_running_task_range": true,
    "use_last_completed_task_range": true
  },
  "attachments": {
    "max_file_count": 8,
    "max_file_size_bytes": 10485760,
    "max_total_size_bytes": 31457280,
    "allowed_extensions": [
      ".txt",
      ".md",
      ".markdown",
      ".json",
      ".csv",
      ".xml",
      ".pdf",
      ".png",
      ".jpg",
      ".jpeg",
      ".webp",
      ".doc",
      ".docx",
      ".xls",
      ".xlsx",
      ".ppt",
      ".pptx",
      ".rtf",
      ".odt",
      ".ods",
      ".odp",
      ".mp4",
      ".mov",
      ".avi",
      ".mkv",
      ".webm",
      ".m4v",
      ".js",
      ".mjs",
      ".cjs",
      ".ts",
      ".tsx",
      ".jsx",
      ".jsonc",
      ".yaml",
      ".yml",
      ".py",
      ".java",
      ".go",
      ".rs",
      ".cpp",
      ".c",
      ".h",
      ".hpp",
      ".cs",
      ".php",
      ".rb",
      ".sh",
      ".bash",
      ".zsh",
      ".sql",
      ".toml",
      ".ini",
      ".env",
      ".log"
    ],
    "attachment_models": {
      "audio": "qwen3_5_omni_plus",
      "video": "qwen3_5_omni_plus",
      "image": "qwen3_5_flash"
    }
  },
  "tools": {
    "max_output_chars": 20000,
    "read_file": {
      "enabled": true
    },
    "write_file": {
      "enabled": true
    },
    "list_skills": {
      "enabled": true
    },
    "set_skill_task": {
      "enabled": true
    },
    "call_service": {
      "enabled": true
    },
    "call_mcp_task": {
      "enabled": true
    },
    "delegate_task_async": {
      "enabled": true,
      "wait_timeout_ms": 120000,
      "max_sub_agent_depth": 3,
      "poll_interval_ms": 5000
    },
    "wait_async_task_result": {
      "enabled": true,
      "poll_interval_ms": 5000
    },
    "plan_multi_task_collaboration": {
      "enabled": true
    },
    "switch_model": {
      "enabled": true
    },
    "user_interaction": {
      "enabled": true
    },
    "web_to_data": {
      "enabled": true,
      "switch_web_mode": "browser_simulate"
    },
    "doc_to_data": {
      "enabled": true,
      "parse_engine": "libreoffice"
    },
    "process_content_task": {
      "enabled": true,
      "max_tool_loop_turns": 50
    },
    "execute_script": {
      "enabled": true,
      "sandbox_mode": true,
      "sandbox_provider": {
        "default": "docker",
        "docker": {
          "docker_container_scope": "global",
          "docker_container_name": "noobot-script-sandbox",
          "docker_image": "node:20",
          "docker_mounts": [
            {
              "source": "",
              "target": "/project",
              "description": "目录映射配置示例：source 与 target 同时非空才会生效；不配置或留空 source 则不映射"
            }
          ]
        },
        "bubblewrap": {},
        "firejail": {}
      },
      "script_timeout_ms": 120000
    },
    "process_connector_tool": {
      "enabled": true,
      "max_tool_loop_turns": 50
    },
    "access_connector": {
      "enabled": true,
      "command_file": {
        "enabled": true,
        "max_bytes": 262144,
        "allowed_extensions": [
          ".sql",
          ".sh",
          ".bash",
          ".zsh",
          ".ksh",
          ".py",
          ".js"
        ],
        "allowed_roots": []
      }
    },
    "database_connect_connector": {
      "enabled": true,
      "connectors": {
        "example_database": {
          "database_type": "mysql",
          "host": "127.0.0.1",
          "port": 3306,
          "username": "readonly_user",
          "password": "${example_database_password}",
          "database": "example_db"
        }
      }
    },
    "terminal_connect_connector": {
      "enabled": true,
      "connectors": {
        "example_terminal": {
          "terminal_type": "ssh",
          "host": "10.0.0.8",
          "port": 22,
          "username": "ops",
          "password": "${example_terminal_password}"
        }
      }
    },
    "inspect_connectors": {
      "enabled": true
    },
    "multimodal_generate": {
      "enabled": true
    },
    "email_connect_connector": {
      "enabled": true,
      "connectors": {
        "example_email": {
          "smtp_host": "${EMAIL_SMTP_HOST}",
          "smtp_port": "${EMAIL_SMTP_PORT}",
          "imap_host": "${EMAIL_IMAP_HOST}",
          "imap_port": "${EMAIL_IMAP_PORT}",
          "username": "${EMAIL_ACCOUNT}",
          "password": "${EMAIL_AUTH_CODE}",
          "from_email": "${EMAIL_FROM_ADDRESS}",
          "to_email": "${EMAIL_TO_ADDRESS}"
        }
      }
    },
    "task_summary": {
      "enabled": true,
      "phase_summary_loop_turns": 15
    },
    "request_help": {
      "enabled": true,
      "help_services": [
        "web_search_service"
      ],
      "help_model": "",
      "help_prompt_loop_turns": 50,
      "tool_failure_help_count": 3
    }
  },
  "scenarios": {
    "default": "full",
    "definitions": {
      "full": {
        "name": "全能",
        "description": "通用情景：不限制工具和上下文，按任务需要自主选择能力。",
        "tools": [
          "*"
        ],
        "context": [
          "*"
        ],
        "services": [
          "*"
        ],
        "mcp_servers": [
          "*"
        ]
      },
      "programming": {
        "name": "编程",
        "description": "优先分析代码结构，再构建完整上下文后执行修改与验证。",
        "model": "qwen3_6_plus_2026_04_02",
        "tools": [
          "execute_script",
          "task_summary",
          "request_help"
        ],
        "context": [
          "scenario",
          "system_runtime",
          "base_prompt",
          "services",
          "mcp_servers"
        ],
        "services": [
          "web_search_service"
        ],
        "mcp_servers": []
      }
    }
  },
  "plugins": {
    "harness": {
      "enabled": true,
      "mode": "off",
      "stepModels": {
        "planning": "qwen3_6_plus",
        "guidance": "qwen3_6_plus",
        "acceptance": "qwen3_6_plus",
        "default": "qwen3_6_plus"
      }
    }
  },
  "preferences": {
    "language": "zh-CN"
  },
  "providers": {
    "gemini_3_flash": {
      "enabled": false,
      "used_for_conversation": true,
      "api_key": "${OPENAI_API_KEY}",
      "base_url": "${OPENAI_API_ADDRESS}",
      "model": "gemini-3-flash",
      "format": "openai_compatible",
      "reasoning_effort": "low",
      "temperature": 0.7,
      "max_tokens": 10000,
      "description": "擅长通用对话、多模态推理",
      "multimodal_generation": {
        "support_understanding": true,
        "support_generation": {
          "enabled": false,
          "support_scope": []
        }
      },
      "top_p": 0.95,
      "frequency_penalty": 0.1,
      "presence_penalty": 0.1
    },
    "nano_banana": {
      "enabled": false,
      "used_for_conversation": false,
      "api_key": "${OPENAI_API_KEY}",
      "base_url": "${OPENAI_API_ADDRESS}",
      "model": "nano-banana",
      "format": "openai_compatible",
      "reasoning_effort": "low",
      "temperature": 0.5,
      "max_tokens": 10000,
      "description": "擅长图片生成",
      "multimodal_generation": {
        "support_understanding": false,
        "support_generation": {
          "enabled": true,
          "support_scope": [
            "image"
          ]
        }
      }
    },
    "qwen3_6_plus": {
      "enabled": true,
      "used_for_conversation": true,
      "api_key": "${DASHSCOPE_API_KEY}",
      "base_url": "${DASHSCOPE_API_ADDRESS}",
      "model": "qwen3.6-plus",
      "format": "dashscope",
      "enable_thinking": false,
      "temperature": 0.7,
      "max_tokens": 10000,
      "preserve_thinking": false,
      "thinking_budget": 0,
      "description": "擅长通用对话、快速响应",
      "multimodal_generation": {
        "support_understanding": false,
        "support_generation": {
          "enabled": false,
          "support_scope": []
        }
      },
      "top_p": 0.9,
      "frequency_penalty": 0.3,
      "presence_penalty": 0.2
    },
    "qwen3_6_plus_2026_04_02": {
      "enabled": true,
      "used_for_conversation": true,
      "api_key": "${DASHSCOPE_API_KEY}",
      "base_url": "${DASHSCOPE_API_ADDRESS}",
      "model": "qwen3.6-plus-2026-04-02",
      "format": "dashscope",
      "enable_thinking": false,
      "temperature": 0.7,
      "max_tokens": 10000,
      "preserve_thinking": false,
      "thinking_budget": 0,
      "description": "擅长通用对话、快速响应",
      "multimodal_generation": {
        "support_understanding": false,
        "support_generation": {
          "enabled": false,
          "support_scope": []
        }
      },
      "top_p": 0.9,
      "frequency_penalty": 0.3,
      "presence_penalty": 0.2
    },
    "qwen3_5_omni_plus": {
      "enabled": false,
      "used_for_conversation": true,
      "api_key": "${DASHSCOPE_API_KEY}",
      "base_url": "${DASHSCOPE_API_ADDRESS}",
      "model": "qwen3.5-omni-plus",
      "format": "dashscope",
      "enable_thinking": false,
      "temperature": 0.7,
      "max_tokens": 10000,
      "preserve_thinking": false,
      "thinking_budget": 0,
      "description": "多模态理解",
      "multimodal_generation": {
        "support_understanding": true,
        "support_generation": {
          "enabled": false,
          "support_scope": []
        }
      },
      "top_p": 0.9,
      "frequency_penalty": 0.3,
      "presence_penalty": 0.2
    }
  },
  "services": {
    "web_search_service": {
      "enabled": true,
      "api_key": "",
      "handler": "web-search-service-handler",
      "prompt": "优先用于补充实时或外部网页信息，先检索再回答。",
      "endpoints": {
        "search": {
          "description": "搜索网页",
          "prompt": "返回可引用的检索结果摘要与来源。",
          "custom_param_format": "searx实例地址",
          "url": "${web_search_service_search_address}",
          "query_string_format": "q=搜索内容",
          "body_format": "{}"
        }
      }
    },
    "weather_service": {
      "enabled": true,
      "api_key": "",
      "handler": "weather-service-handler",
      "prompt": "用于天气类查询，优先返回结构化天气信息。",
      "endpoints": {
        "get_weather": {
          "description": "天气查询",
          "prompt": "输入城市名，返回当前与未来天气。",
          "custom_param_format": "j1",
          "url": "https://wttr.in",
          "query_string_format": "{\"city\":\"\",\"format\":\"j1\"}",
          "body_format": "{}"
        }
      }
    }
  },
  "mcp_servers": {
    "china-railway": {
      "type": "sse",
      "description": "提供 12306购票信息查询等服务",
      "prompt": "用于铁路票务查询场景，先说明查询条件再调用。",
      "isActive": true,
      "name": "AliyunBailianMCP_china-railway",
      "baseUrl": "https://dashscope.aliyuncs.com/api/v1/mcps/china-railway/sse",
      "headers": {
        "Authorization": "Bearer ${DASHSCOPE_API_KEY_MCP}"
      }
    }
  },
  "streaming": true,
  "super_admin": {
    "user_id": "admin",
    "connect_code": "change-your-connect-code"
  },
  "run_timeout_ms": 7200000
}
