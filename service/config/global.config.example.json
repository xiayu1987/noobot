{
  "workspace_root": "../workspace",
  "workspace_template_path": "../user-template/default-user",
  "default_provider": "qwen3_6_plus_2026_04_02",
  "memory_max_items": 50,
  "max_tool_loop_turns": 50,
  "session": {
    "recent_message_limit": 20,
    "use_last_running_task_range": true,
    "use_last_completed_task_range": true
  },
  "attachments": {
    "max_file_count": 8,
    "max_file_size_bytes": 10485760,
    "max_total_size_bytes": 31457280,
    "allowed_extensions": [
      ".txt",
      ".md",
      ".markdown",
      ".json",
      ".csv",
      ".xml",
      ".pdf",
      ".png",
      ".jpg",
      ".jpeg",
      ".webp",
      ".doc",
      ".docx",
      ".xls",
      ".xlsx",
      ".ppt",
      ".pptx",
      ".rtf",
      ".odt",
      ".ods",
      ".odp",
      ".mp4",
      ".mov",
      ".avi",
      ".mkv",
      ".webm",
      ".m4v",
      ".js",
      ".mjs",
      ".cjs",
      ".ts",
      ".tsx",
      ".jsx",
      ".jsonc",
      ".yaml",
      ".yml",
      ".py",
      ".java",
      ".go",
      ".rs",
      ".cpp",
      ".c",
      ".h",
      ".hpp",
      ".cs",
      ".php",
      ".rb",
      ".sh",
      ".bash",
      ".zsh",
      ".sql",
      ".toml",
      ".ini",
      ".env",
      ".log"
    ],
    "attachment_models": {
      "audio": "qwen3_5_omni_plus",
      "video": "qwen3_5_omni_plus",
      "image": "qwen3_5_flash"
    }
  },
  "tools": {
    "read_file": {
      "enabled": true
    },
    "write_file": {
      "enabled": true
    },
    "list_skills": {
      "enabled": true
    },
    "set_skill_task": {
      "enabled": true
    },
    "call_service": {
      "enabled": true
    },
    "call_mcp_task": {
      "enabled": true
    },
    "delegate_task_async": {
      "enabled": true,
      "wait_timeout_ms": 120000,
      "max_sub_agent_depth": 3,
      "poll_interval_ms": 5000
    },
    "wait_async_task_result": {
      "enabled": true,
      "poll_interval_ms": 5000
    },
    "plan_multi_task_collaboration": {
      "enabled": true
    },
    "switch_model": {
      "enabled": true
    },
    "user_interaction": {
      "enabled": true
    },
    "web_to_data": {
      "enabled": true,
      "switch_web_mode": "browser_simulate"
    },
    "doc_to_data": {
      "enabled": true
    },
    "process_content_task": {
      "enabled": true,
      "max_tool_loop_turns": 50
    },
    "execute_script": {
      "enabled": true,
      "sandbox_mode": true,
      "sandbox_provider": {
        "default": "docker",
        "docker": {
          "docker_container_scope": "global",
          "docker_container_name": "noobot-script-sandbox",
          "docker_image": "node:20"
        },
        "bubblewrap": {},
        "firejail": {}
      },
      "script_timeout_ms": 120000
    },
    "process_connector_tool": {
      "enabled": true,
      "max_tool_loop_turns": 50
    },
    "access_connector": {
      "enabled": true,
      "max_output_chars": 8000
    },
    "database_connect_connector": {
      "enabled": true,
      "connectors": {
        "example_database": {
          "database_type": "mysql",
          "host": "127.0.0.1",
          "port": 3306,
          "username": "readonly_user",
          "password": "${example_database_password}",
          "database": "example_db"
        }
      }
    },
    "terminal_connect_connector": {
      "enabled": true,
      "connectors": {
        "example_terminal": {
          "terminal_type": "ssh",
          "host": "10.0.0.8",
          "port": 22,
          "username": "ops",
          "password": "${example_terminal_password}"
        }
      }
    },
    "inspect_connectors": {
      "enabled": true
    },
    "multimodal_generate": {
      "enabled": true
    },
    "email_connect_connector": {
      "enabled": true,
      "connectors": {
        "example_email": {
          "smtp_host": "${EMAIL_SMTP_HOST}",
          "smtp_port": "${EMAIL_SMTP_PORT}",
          "imap_host": "${EMAIL_IMAP_HOST}",
          "imap_port": "${EMAIL_IMAP_PORT}",
          "username": "${EMAIL_ACCOUNT}",
          "password": "${EMAIL_AUTH_CODE}",
          "from_email": "${EMAIL_FROM_ADDRESS}",
          "to_email": "${EMAIL_TO_ADDRESS}"
        }
      }
    }
  },
  "providers": {
    "gemini_3_flash": {
      "enabled": false,
      "used_for_conversation": true,
      "api_key": "${OPENAI_API_KEY}",
      "base_url": "${OPENAI_API_ADDRESS}",
      "model": "gemini-3-flash",
      "format": "openai_compatible",
      "reasoning_effort": "low",
      "temperature": 0.5,
      "max_tokens": 10000,
      "description": "擅长通用对话、多模态推理",
      "multimodal_generation": {
        "support_understanding": true,
        "support_generation": {
          "enabled": false,
          "support_scope": []
        }
      }
    },
    "nano_banana": {
      "enabled": false,
      "used_for_conversation": false,
      "api_key": "${OPENAI_API_KEY}",
      "base_url": "${OPENAI_API_ADDRESS}",
      "model": "nano-banana",
      "format": "openai_compatible",
      "reasoning_effort": "low",
      "temperature": 0.5,
      "max_tokens": 10000,
      "description": "擅长图片生成",
      "multimodal_generation": {
        "support_understanding": false,
        "support_generation": {
          "enabled": true,
          "support_scope": [
            "image"
          ]
        }
      }
    },
    "qwen3_6_plus_2026_04_02": {
      "enabled": true,
      "used_for_conversation": true,
      "api_key": "${DASHSCOPE_API_KEY}",
      "base_url": "${DASHSCOPE_API_ADDRESS}",
      "model": "qwen3.6-plus-2026-04-02",
      "format": "dashscope",
      "temperature": 0.5,
      "max_tokens": 10000,
      "preserve_thinking": false,
      "thinking_budget": 1,
      "description": "擅长通用对话、快速响应",
      "multimodal_generation": {
        "support_understanding": false,
        "support_generation": {
          "enabled": false,
          "support_scope": []
        }
      }
    },
    "qwen3_5_omni_plus": {
      "enabled": false,
      "used_for_conversation": true,
      "api_key": "${DASHSCOPE_API_KEY}",
      "base_url": "${DASHSCOPE_API_ADDRESS}",
      "model": "qwen3.5-omni-plus",
      "format": "dashscope",
      "temperature": 0.5,
      "max_tokens": 10000,
      "preserve_thinking": false,
      "thinking_budget": 1,
      "description": "多模态理解",
      "multimodal_generation": {
        "support_understanding": true,
        "support_generation": {
          "enabled": false,
          "support_scope": []
        }
      }
    }
  },
  "mcp_servers": {
    "china-railway": {
      "type": "sse",
      "description": "提供 12306购票信息查询等服务",
      "isActive": true,
      "name": "AliyunBailianMCP_china-railway",
      "baseUrl": "https://dashscope.aliyuncs.com/api/v1/mcps/china-railway/sse",
      "headers": {
        "Authorization": "Bearer ${DASHSCOPE_API_KEY_MCP}"
      }
    }
  },
  "streaming": true,
  "super_admin": {
    "user_id": "admin",
    "connect_code": "change-your-connect-code"
  }
}
