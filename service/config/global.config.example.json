{
  "workspace_root": "../workspace",
  "workspace_template_path": "../user-template/default-user",
  "default_provider": "qwen3_5_flash",
  "memory_max_items": 50,
  "max_tool_loop_turns": 30,
  "session": {
    "recent_message_limit": 20,
    "use_last_running_task_range": true,
    "use_last_completed_task_range": true
  },
  "tools": {
    "read_file": {
      "enabled": true
    },
    "write_file": {
      "enabled": true
    },
    "list_skills": {
      "enabled": true
    },
    "set_skill_task": {
      "enabled": true
    },
    "call_service": {
      "enabled": true
    },
    "call_mcp_task": {
      "enabled": true
    },
    "delegate_task_async": {
      "enabled": true,
      "wait_timeout_ms": 120000,
      "max_sub_agent_depth": 3,
      "poll_interval_ms": 5000
    },
    "wait_async_task_result": {
      "enabled": true,
      "poll_interval_ms": 5000
    },
    "plan_multi_task_collaboration": {
      "enabled": true
    },
    "switch_model": {
      "enabled": true
    },
    "user_interaction": {
      "enabled": true
    },
    "web_to_data": {
      "enabled": true,
      "switch_web_mode": "browser_simulate"
    },
    "doc_to_data": {
      "enabled": true
    },
    "process_content_task": {
      "enabled": true,
      "max_tool_loop_turns": 2
    },
    "execute_script": {
      "enabled": true,
      "sandbox_mode": true,
      "sandbox_provider": {
        "default": "docker",
        "docker": {
          "docker_container_scope": "global",
          "docker_container_name": "noobot-script-sandbox",
          "docker_image": "node:20"
        },
        "bubblewrap": {},
        "firejail": {}
      },
      "script_timeout_ms": 120000
    },
    "process_connector_tool": {
      "enabled": true,
      "max_tool_loop_turns": 20
    },
    "access_connector": {
      "enabled": true,
      "max_output_chars": 8000
    },
    "database_connect_connector": {
      "enabled": true,
      "connectors": {
        "example_database": {
          "database_type": "mysql",
          "host": "127.0.0.1",
          "port": 3306,
          "username": "readonly_user",
          "password": "${example_database_password}",
          "database": "example_db"
        }
      }
    },
    "terminal_connect_connector": {
      "enabled": true,
      "connectors": {
        "example_terminal": {
          "terminal_type": "ssh",
          "host": "10.0.0.8",
          "port": 22,
          "username": "ops",
          "password": "${example_terminal_password}"
        }
      }
    },
    "inspect_connectors": {
      "enabled": true
    }
  },
  "providers": {
    "openai": {
      "enabled": false,
      "api_key": "${OPENAI_API_KEY}",
      "base_url": "",
      "model": "gemini-3.1-pro",
      "format": "openai_compatible",
      "reasoning_effort": "low",
      "temperature": 0.5,
      "max_tokens": 10000,
      "description": ""
    },
    "qwen3_5_flash": {
      "enabled": true,
      "api_key": "${DASHSCOPE_API_KEY}",
      "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "model": "qwen3.6-plus-2026-04-02",
      "format": "dashscope",
      "temperature": 0.5,
      "max_tokens": 10000,
      "preserve_thinking": false,
      "thinking_budget": 1,
      "description": "擅长通用对话、快速响应与多模态理解"
    }
  },
  "mcp_servers": {
    "china-railway": {
      "type": "sse",
      "description": "提供 12306购票信息查询等服务",
      "isActive": true,
      "name": "AliyunBailianMCP_china-railway",
      "baseUrl": "https://dashscope.aliyuncs.com/api/v1/mcps/china-railway/sse",
      "headers": {
        "Authorization": "Bearer ${DASHSCOPE_API_KEY_MCP}"
      }
    }
  },
  "streaming": true,
  "super_admin": {
    "user_id": "admin",
    "connect_code": "change-your-connect-code"
  }
}
