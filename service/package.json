{
  "name": "noobot-project",
  "version": "1.0.0",
  "type": "module",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "node --watch app.js",
    "test:bot-manage": "node --test __tests__/system-core/bot-manage/index.test.js",
    "check:tool-schema:live:gemini:admin": "node scripts/check-openai-tool-schema.js --live --model gemini_3_flash --userId admin",
    "postinstall": "playwright install chromium",
    "init": "node scripts/init.js",
    "pm2:start": "PM2_HOME=../.pm2 npx pm2 start app.js --name noobot-service",
    "pm2:restart": "PM2_HOME=../.pm2 npx pm2 restart noobot-service",
    "pm2:stop": "PM2_HOME=../.pm2 npx pm2 stop noobot-service",
    "pm2:delete": "PM2_HOME=../.pm2 npx pm2 delete noobot-service",
    "pm2:logs": "PM2_HOME=../.pm2 npx pm2 logs noobot-service",
    "pm2:list": "PM2_HOME=../.pm2 npx pm2 list",
    "test": "node --test __tests__/**/*.test.js __tests__/system-core/bot-manage/index.test.js",
    "test:utils": "node --test __tests__/utils/*.test.js",
    "test:connectors": "node --test __tests__/connectors/**/*.test.js"
  },
  "dependencies": {
    "@langchain/core": "^1.1.45",
    "@langchain/openai": "^1.4.5",
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "imapflow": "^1.3.2",
    "jscpd": "^4.1.0",
    "jsdom": "^29.0.2",
    "libreoffice": "^0.4.5",
    "mailparser": "^3.9.0",
    "mysql2": "^3.22.2",
    "node-poppler": "^9.1.1",
    "nodemailer": "^8.0.6",
    "openai": "^6.34.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "playwright": "^1.59.1",
    "pm2": "^7.0.1",
    "sharp": "^0.34.5",
    "ssh2": "^1.17.0",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "yazl": "^3.3.1",
    "zod": "^4.3.6"
  }
}
