{
  "name": "noobot-service",
  "version": "4.0.2",
  "type": "module",
  "imports": {
    "#agent/config": "./deps/agent-config.js",
    "#agent/connectors": "./deps/agent-connectors.js",
    "#agent/bot-manage": "./deps/agent-bot-manage.js",
    "#agent/model": "./deps/agent-model.js",
    "#agent/tracking": "./deps/agent-tracking.js",
    "#agent/constants": "./deps/agent-constants.js",
    "#agent/utils": "./deps/agent-utils.js",
    "#agent/event": "./deps/agent-event.js",
    "#agent/plugin": "./deps/agent-plugin.js"
  },
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "node --watch app.js",
    "test:bot-manage": "npm --prefix ../agent run test:bot-manage",
    "check:tool-schema:live:gemini:admin": "npm --prefix ../agent run check:tool-schema:live:gemini:admin",
    "postinstall": "playwright install chromium",
    "init": "node scripts/init.js",
    "pm2:start": "PM2_HOME=../.pm2 npx pm2 start app.js --name noobot-service",
    "pm2:restart": "PM2_HOME=../.pm2 npx pm2 restart noobot-service",
    "pm2:stop": "PM2_HOME=../.pm2 npx pm2 stop noobot-service",
    "pm2:delete": "PM2_HOME=../.pm2 npx pm2 delete noobot-service",
    "pm2:logs": "PM2_HOME=../.pm2 npx pm2 logs noobot-service",
    "pm2:list": "PM2_HOME=../.pm2 npx pm2 list",
    "test": "node --test __tests__/project-launcher.test.js __tests__/routes/*.test.js",
    "test:tools": "npm --prefix ../agent run test:tools",
    "test:routes": "node --test __tests__/routes/*.test.js",
    "lint:tools-constants": "eslint .",
    "lint:service-constants": "eslint .",
    "check:i18n-imports": "node ../scripts/check-i18n-imports.mjs --project=service",
    "pretest": "npm run -s check:i18n-imports",
    "install:openvscode-server": "node scripts/install-openvscode-server.mjs",
    "ensure:openvscode-server": "node scripts/install-openvscode-server.mjs"
  },
  "dependencies": {
    "@langchain/core": "^1.2.0",
    "@langchain/openai": "^1.5.1",
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "imapflow": "^1.4.2",
    "jscpd": "^5.0.11",
    "jsdom": "^29.1.1",
    "libreoffice": "^0.4.5",
    "mailparser": "^3.9.11",
    "mysql2": "^3.22.5",
    "node-poppler": "^9.1.2",
    "nodemailer": "^9.0.1",
    "@noobot/shared": "file:../shared",
    "noobot-agent": "file:../agent",
    "noobot-i18n": "file:../i18n",
    "openai": "^6.44.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "playwright": "^1.61.0",
    "pm2": "^7.0.1",
    "sharp": "^0.35.2",
    "ssh2": "^1.17.0",
    "uuid": "^14.0.1",
    "ws": "^8.21.0",
    "yazl": "^3.3.1",
    "zod": "^4.4.3",
    "@noobot/runtime-events": "file:../runtime-events"
  },
  "overrides": {
    "systeminformation": "^5.31.7"
  },
  "devDependencies": {
    "eslint": "^10.5.0"
  }
}
