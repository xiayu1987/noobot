{
  "name": "noobot",
  "version": "1.1.0",
  "private": true,
  "workspaces": [
    "service",
    "agent",
    "agent-proxy",
    "model-proxy",
    "i18n",
    "workflow",
    "plugin/noobot-plugin-harness",
    "plugin/noobot-plugin-workflow",
    "client/noobot-chat"
  ],
  "scripts": {
    "project:launcher": "node ./scripts/project-launcher.mjs",
    "install:all": "npm install --workspaces",
    "build": "npm run -w client/noobot-chat build",
    "check:legacy-time-keys": "node ./scripts/check-legacy-time-keys.mjs",
    "dev:service": "npm run -w service dev",
    "dev:agent-proxy": "npm run -w agent-proxy dev",
    "dev:client": "npm run -w client/noobot-chat dev",
    "test": "npm run --workspaces --if-present test",
    "check:i18n-imports": "npm run --workspaces --if-present check:i18n-imports",
    "check:plugin-frontend-i18n": "node ./scripts/check-plugin-frontend-i18n.mjs",
    "check:semantic-transfer-compat": "node ./scripts/check-semantic-transfer-compat.mjs",
    "check:parent-sessionid-unification": "node ./scripts/check-parent-sessionid-unification.mjs",
    "check:plugin-harness-src-i18n": "node ./scripts/check-plugin-harness-src-i18n.mjs",
    "check:plugin-harness-i18n-keyset": "node ./scripts/check-plugin-harness-i18n-keyset.mjs",
    "check:plugin-workflow-src-i18n": "node ./scripts/check-plugin-workflow-src-i18n.mjs",
    "check:plugin-workflow-i18n-keyset": "node ./scripts/check-plugin-workflow-i18n-keyset.mjs",
    "check:plugin-i18n": "npm run -s check:plugin-harness-src-i18n && npm run -s check:plugin-harness-i18n-keyset && npm run -s check:plugin-workflow-src-i18n && npm run -s check:plugin-workflow-i18n-keyset && npm run -s check:plugin-frontend-i18n",
    "check:agent-plugin-decoupling": "node ./scripts/check-agent-plugin-decoupling.mjs"
  }
}
