{
  "name": "noobot-windows-client",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NOOBOT_CLIENT_URL=${NOOBOT_CLIENT_URL:-http://127.0.0.1:10060} electron .",
    "prepare:frontend": "npm --prefix ../noobot-chat run build",
    "build:win": "npm run prepare:frontend && npm run prepare:backend && electron-builder --win",
    "build:win:dir": "npm run prepare:frontend && npm run prepare:backend && electron-builder --win --dir",
    "check": "node --check src/main.js && node --check src/preload.cjs",
    "prepare:backend": "node scripts/prepare-backend-runtime.mjs",
    "build:win:portable": "npm run prepare:frontend && npm run prepare:backend && electron-builder --win portable",
    "build:win:zip": "npm run prepare:frontend && npm run prepare:backend && electron-builder --win zip"
  },
  "devDependencies": {
    "electron": "39.8.10",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.noobot.windows-client",
    "productName": "Noobot",
    "compression": "store",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [],
    "win": {
      "icon": "assets/noobot.ico",
      "target": [
        "nsis",
        "portable",
        "zip"
      ]
    },
    "afterPack": "scripts/copy-backend-after-pack.mjs"
  }
}
