{
  "name": "noobot-chat",
  "private": true,
  "version": "4.1.0",
  "type": "module",
  "scripts": {
    "generate:frontend-plugin-entries": "node scripts/generate-frontend-plugin-entries.mjs",
    "check:plugin-frontend-reverse-deps": "node scripts/check-plugin-frontend-reverse-deps.mjs",
    "prebuild": "npm run -s generate:frontend-plugin-entries",
    "dev": "vite",
    "build": "vite build",
    "test": "NODE_OPTIONS=--no-experimental-webstorage vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "serve:caddy": "bash ./deploy/run-caddy.sh",
    "serve:caddy:restart": "bash ./deploy/restart-caddy.sh",
    "check:i18n-imports": "node ../../scripts/check-i18n-imports.mjs --project=client",
    "pretest": "npm run -s generate:frontend-plugin-entries && npm run -s check:plugin-frontend-reverse-deps && npm run -s check:i18n-imports"
  },
  "dependencies": {
    "@noobot/shared": "file:../../shared",
    "@element-plus/icons-vue": "^2.3.2",
    "element-plus": "^2.14.3",
    "markdown-it": "^14.3.0",
    "mermaid": "^11.16.0",
    "pinia": "^4.0.2",
    "vue": "^3.5.40",
    "noobot-i18n": "file:../../i18n"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "glob": "^13.0.6",
    "uuid": "^14.0.1"
  }
}
