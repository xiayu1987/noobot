{
  "name": "noobot-mac-client",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NOOBOT_CLIENT_URL=${NOOBOT_CLIENT_URL:-http://127.0.0.1:10060} electron .",
    "prepare:frontend": "npm --prefix ../noobot-chat run build",
    "prepare:backend": "node scripts/prepare-backend-runtime.mjs",
    "check": "node --check src/main.js && node --check ../shared/electron/main.js && node --check ../shared/electron/preload.cjs",
    "build:mac": "npm run prepare:frontend && npm run prepare:backend && electron-builder --mac",
    "build:mac:dir": "npm run prepare:frontend && npm run prepare:backend && electron-builder --mac --dir",
    "build:mac:dmg": "npm run prepare:frontend && npm run prepare:backend && electron-builder --mac dmg",
    "build:mac:zip": "npm run prepare:frontend && npm run prepare:backend && electron-builder --mac zip"
  },
  "devDependencies": {
    "electron": "39.8.10",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.noobot.mac-client",
    "productName": "Noobot",
    "compression": "store",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../shared",
        "to": "shared",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "afterPack": "scripts/copy-backend-after-pack.mjs"
  }
}
