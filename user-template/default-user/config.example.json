{
  "defaultProvider": "qwen3_5_flash",
  "attachmentModels": {
    "audio": "omni",
    "video": "qwen3_5_flash",
    "image": "qwen3_5_flash"
  },
  "tools": {
    "web_search_to_data": {
      "enabled": true,
      "searchMode": "browser_simulate",
      "switchWebMode": "browser_simulate",
      "maxCandidates": 30,
      "topK": 10
    },
    "web_to_data": {
      "enabled": true,
      "switchWebMode": "browser_simulate"
    },
    "doc_to_data": {
      "enabled": true
    },
    "process_content_task": {
      "enabled": true,
      "maxToolLoopTurns": 2
    }
  },
  "providers": {
    "openai": {
      "enabled": false,
      "api_key": "${OPENAI_API_KEY}",
      "base_url": "",
      "model": "gemini-3.1-pro",
      "format": "openai_compatible",
      "reasoning_effort": "low",
      "temperature": 0.5,
      "max_tokens": 10000,
      "description": ""
    },
    "qwen3_5_flash": {
      "enabled": true,
      "api_key": "${DASHSCOPE_API_KEY}",
      "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "model": "qwen3.6-plus-2026-04-02",
      "format": "dashscope",
      "temperature": 0.5,
      "max_tokens": 10000,
      "preserve_thinking": false,
      "thinking_budget": 1,
      "description": "擅长通用对话、快速响应与多模态理解"
    }
  },
  "services": {
    "webSearchService": {
      "enabled": true,
      "api_key": "",
      "handler": "webSearchServiceHandler",
      "endpoints": {
        "search": {
          "description": "搜索网页",
          "url": "http://localhost:11008/search",
          "query-string-format": "q=搜索内容",
          "body-format": "{}"
        }
      }
    },
    "weatherService": {
      "enabled": true,
      "api_key": "",
      "handler": "weatherServiceHandler",
      "endpoints": {
        "getWeather": {
          "description": "天气查询",
          "url": "https://wttr.in",
          "query-string-format": "{\"city\":\"\",\"format\":\"j1\"}",
          "body-format": "{}"
        }
      }
    }
  },
  "mcpServers": {
    "china-railway": {
      "type": "sse",
      "description": "提供 12306购票信息查询等服务",
      "isActive": true,
      "name": "AliyunBailianMCP_china-railway",
      "baseUrl": "https://dashscope.aliyuncs.com/api/v1/mcps/china-railway/sse",
      "headers": {
        "Authorization": "Bearer ${DASHSCOPE_API_KEY_MCP}"
      }
    }
  },
  "preferences": {
    "language": "zh-CN"
  }
}
