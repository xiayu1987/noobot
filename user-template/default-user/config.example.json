{
  "default_provider": "GLM_5_1",
  "attachments": {
    "attachment_models": {
      "audio": "qwen3_5_omni_plus",
      "video": "qwen3_5_omni_plus",
      "image": "qwen3_5_omni_plus"
    }
  },
  "tools": {
    "read_file": {
      "enabled": true
    },
    "write_file": {
      "enabled": true
    },
    "list_skills": {
      "enabled": true
    },
    "set_skill_task": {
      "enabled": true
    },
    "call_service": {
      "enabled": true
    },
    "call_mcp_task": {
      "enabled": true
    },
    "delegate_task_async": {
      "enabled": true
    },
    "wait_async_task_result": {
      "enabled": true
    },
    "plan_multi_task_collaboration": {
      "enabled": true
    },
    "switch_model": {
      "enabled": true
    },
    "user_interaction": {
      "enabled": true
    },
    "task_summary": {
      "enabled": true
    },
    "request_help": {
      "enabled": true,
      "help_services": [
        "web_search_service"
      ],
      "help_model": ""
    },
    "web_to_data": {
      "enabled": true,
      "switch_web_mode": "browser_simulate"
    },
    "doc_to_data": {
      "enabled": true,
      "parse_engine": "libreoffice"
    },
    "process_content_task": {
      "enabled": true
    },
    "execute_script": {
      "enabled": true,
      "sandbox_mode": true,
      "sandbox_provider": {
        "default": "docker",
        "docker": {
          "docker_container_scope": "global",
          "docker_container_name": "noobot-script-sandbox",
          "docker_image": "nikolaik/python-nodejs:python3.12-nodejs26-bookworm"
        },
        "bubblewrap": {},
        "firejail": {}
      }
    },
    "process_connector_tool": {
      "enabled": true
    },
    "access_connector": {
      "enabled": true,
      "command_file": {
        "enabled": true,
        "allowed_roots": []
      }
    },
    "database_connect_connector": {
      "enabled": true,
      "connectors": {
        "example_database": {
          "database_type": "mysql",
          "host": "127.0.0.1",
          "port": 3306,
          "username": "readonly_user",
          "password": "${example_database_password}",
          "database": "example_db"
        }
      }
    },
    "terminal_connect_connector": {
      "enabled": true,
      "connectors": {
        "example_terminal": {
          "terminal_type": "ssh",
          "host": "10.0.0.8",
          "port": 22,
          "username": "ops",
          "password": "${example_terminal_password}"
        }
      }
    },
    "inspect_connectors": {
      "enabled": true
    },
    "multimodal_generate": {
      "enabled": true
    },
    "email_connect_connector": {
      "enabled": true,
      "connectors": {
        "example_email": {
          "smtp_host": "${EMAIL_SMTP_HOST}",
          "smtp_port": "${EMAIL_SMTP_PORT}",
          "imap_host": "${EMAIL_IMAP_HOST}",
          "imap_port": "${EMAIL_IMAP_PORT}",
          "username": "${EMAIL_ACCOUNT}",
          "password": "${EMAIL_AUTH_CODE}",
          "from_email": "${EMAIL_FROM_ADDRESS}",
          "to_email": "${EMAIL_TO_ADDRESS}"
        }
      }
    }
  },
  "scenarios": {
    "default": "full",
    "definitions": {
      "full": {
        "name": "全能",
        "description": "通用情景：不限制工具和上下文，按任务需要自主选择能力。",
        "tools": [
          "*"
        ],
        "context": [
          "*"
        ],
        "services": [
          "*"
        ],
        "mcp_servers": [
          "*"
        ]
      },
      "programming": {
        "name": "编程",
        "description": "优先分析代码结构，再构建完整上下文后执行修改与验证。",
        "model": "GLM_5_1",
        "tools": [
          "execute_script",
          "task_summary",
          "request_help"
        ],
        "context": [
          "scenario",
          "system_runtime",
          "base_prompt",
          "services",
          "mcp_servers"
        ],
        "services": [
          "web_search_service"
        ],
        "mcp_servers": []
      }
    }
  },
  "plugins": {
    "harness": {
      "enabled": true,
      "mode": "off",
      "stepModels": {
        "planning": "GLM_5_1",
        "guidance": "GLM_5_1",
        "acceptance": "GLM_5_1",
        "default": "GLM_5_1"
      }
    },
    "workflow": {
      "enabled": true,
      "mode": "off",
      "semanticModel": "GLM_5_1"
    }
  },
  "providers": {
    "GLM_5_1": {
      "enabled": true,
      "used_for_conversation": true,
      "api_key": "${DASHSCOPE_API_KEY}",
      "base_url": "${DASHSCOPE_API_ADDRESS}",
      "model": "ZHIPU/GLM-5.1",
      "format": "dashscope",
      "temperature": 0.7,
      "max_tokens": 10000,
      "preserve_thinking": false,
      "thinking_budget": 0,
      "description": "擅长通用对话、快速响应",
      "multimodal_generation": {
        "support_understanding": false,
        "support_generation": {
          "enabled": false,
          "support_scope": []
        }
      },
      "top_p": 0.9,
      "frequency_penalty": 0.3,
      "presence_penalty": 0.2
    }
  },
  "services": {
    "web_search_service": {
      "enabled": true,
      "api_key": "",
      "handler": "web-search-service-handler",
      "prompt": "优先用于补充实时或外部网页信息，优先关键词搜索，再精确搜索，最后再回答。",
      "endpoints": {
        "search": {
          "description": "搜索网页",
          "prompt": "返回可引用的检索结果摘要与来源。",
          "custom_param_format": "searx实例地址",
          "url": "${web_search_service_search_address}",
          "query_string_format": "q=搜索内容",
          "body_format": "{}"
        }
      }
    },
    "weather_service": {
      "enabled": true,
      "api_key": "",
      "handler": "weather-service-handler",
      "prompt": "用于天气类查询，优先返回结构化天气信息。",
      "endpoints": {
        "get_weather": {
          "description": "天气查询",
          "prompt": "输入城市名，返回当前与未来天气。",
          "custom_param_format": "j1",
          "url": "https://wttr.in",
          "query_string_format": "{\"city\":\"\",\"format\":\"j1\"}",
          "body_format": "{}"
        }
      }
    }
  },
  "mcp_servers": {
    "china-railway": {
      "type": "sse",
      "description": "提供 12306购票信息查询等服务",
      "prompt": "用于铁路票务查询场景，先说明查询条件再调用。",
      "isActive": true,
      "name": "AliyunBailianMCP_china-railway",
      "baseUrl": "https://dashscope.aliyuncs.com/api/v1/mcps/china-railway/sse",
      "headers": {
        "Authorization": "Bearer ${DASHSCOPE_API_KEY_MCP}"
      }
    }
  },
  "preferences": {
    "language": "zh-CN"
  }
}
