{
  "default_provider": "qwen3_5_flash",
  "attachment_models": {
    "audio": "omni",
    "video": "qwen3_5_flash",
    "image": "qwen3_5_flash"
  },
  "tools": {
    "read_file": {
      "enabled": true
    },
    "write_file": {
      "enabled": true
    },
    "list_skills": {
      "enabled": true
    },
    "set_skill_task": {
      "enabled": true
    },
    "call_service": {
      "enabled": true
    },
    "call_mcp_task": {
      "enabled": true
    },
    "delegate_task_async": {
      "enabled": true,
      "wait_timeout_ms": 120000,
      "max_sub_agent_depth": 3,
      "poll_interval_ms": 5000
    },
    "wait_async_task_result": {
      "enabled": true,
      "poll_interval_ms": 5000
    },
    "plan_multi_task_collaboration": {
      "enabled": true
    },
    "switch_model": {
      "enabled": true
    },
    "user_interaction": {
      "enabled": true
    },
    "web_to_data": {
      "enabled": true,
      "switch_web_mode": "browser_simulate"
    },
    "doc_to_data": {
      "enabled": true
    },
    "process_content_task": {
      "enabled": true,
      "max_tool_loop_turns": 2
    },
    "execute_script": {
      "enabled": true,
      "sandbox_mode": true,
      "sandbox_provider": {
        "default": "docker",
        "docker": {
          "docker_container_scope": "global",
          "docker_container_name": "noobot-script-sandbox",
          "docker_image": "node:20"
        },
        "bubblewrap": {},
        "firejail": {}
      },
      "script_timeout_ms": 120000
    }
  },
  "providers": {
    "openai": {
      "enabled": false,
      "api_key": "${OPENAI_API_KEY}",
      "base_url": "",
      "model": "gemini-3.1-pro",
      "format": "openai_compatible",
      "reasoning_effort": "low",
      "temperature": 0.5,
      "max_tokens": 10000,
      "description": ""
    },
    "qwen3_5_flash": {
      "enabled": true,
      "api_key": "${DASHSCOPE_API_KEY}",
      "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "model": "qwen3.6-plus-2026-04-02",
      "format": "dashscope",
      "temperature": 0.5,
      "max_tokens": 10000,
      "preserve_thinking": false,
      "thinking_budget": 1,
      "description": "擅长通用对话、快速响应与多模态理解"
    }
  },
  "services": {
    "web_search_service": {
      "enabled": true,
      "api_key": "",
      "handler": "web-search-service-handler",
      "endpoints": {
        "search": {
          "description": "搜索网页",
          "custom_param_format": "searx实例地址",
          "url": "${web_search_service_search_address}",
          "query_string_format": "q=搜索内容",
          "body_format": "{}"
        }
      }
    },
    "weather_service": {
      "enabled": true,
      "api_key": "",
      "handler": "weather-service-handler",
      "endpoints": {
        "get_weather": {
          "description": "天气查询",
          "custom_param_format": "j1",
          "url": "https://wttr.in",
          "query_string_format": "{\"city\":\"\",\"format\":\"j1\"}",
          "body_format": "{}"
        }
      }
    }
  },
  "mcp_servers": {
    "china-railway": {
      "type": "sse",
      "description": "提供 12306购票信息查询等服务",
      "isActive": true,
      "name": "AliyunBailianMCP_china-railway",
      "baseUrl": "https://dashscope.aliyuncs.com/api/v1/mcps/china-railway/sse",
      "headers": {
        "Authorization": "Bearer ${DASHSCOPE_API_KEY_MCP}"
      }
    }
  },
  "preferences": {
    "language": "zh-CN"
  }
}
