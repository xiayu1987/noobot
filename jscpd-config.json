{
  "patterns": [
    "service/src/**/*.{js,ts,jsx,tsx}",
    "client/**/*.{js,ts,jsx,tsx}",
    "agent-proxy/**/*.{js,ts}",
    "model-proxy/**/*.{js,ts}"
  ],
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/*.test.{js,ts,jsx,tsx}",
    "**/*.spec.{js,ts,jsx,tsx}",
    "**/__tests__/**",
    "**/__mocks__/**",
    "**/*.d.ts",
    "**/workspace/**",
    "**/report/**"
  ],
  "minLines": 5,
  "minTokens": 70,
  "reporters": ["json"],
  "output": "/project/report/jscpd-report.json",
  "absolute": true
}
