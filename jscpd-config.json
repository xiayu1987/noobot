{
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/*.test.{js,ts,jsx,tsx}",
    "**/*.spec.{js,ts,jsx,tsx}",
    "**/__tests__/**",
    "**/__mocks__/**",
    "**/*.d.ts",
    "**/*.md",
    "**/*.svg",
    "**/*.txt",
    "**/workspace/**",
    "**/report/**"
  ],
  "minLines": 5,
  "minTokens": 70,
  "threshold": 3,
  "reporters": ["console", "json"],
  "output": "/project/report",
  "absolute": true
}
