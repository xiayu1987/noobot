{
  "id": "workflow",
  "pluginKey": "workflow",
  "name": "noobot-plugin-workflow",
  "version": "1.1.0",
  "capabilities": [
    "agent.workflow",
    "service.after_session_delete",
    "bot.register"
  ],
  "runtimeOptions": {
    "service.after_session_delete": {
      "enabled": true,
      "mode": "on",
      "priority": 10,
      "timeoutMs": 5000
    }
  },
  "apiVersion": "1",
  "entry": "src/index.js",
  "frontend": {
    "apiVersion": "1",
    "entry": "frontend/index.js"
  },
  "enabledByDefault": true
}
