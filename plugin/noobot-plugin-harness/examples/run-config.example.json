{
  "plugins": {
    "harness": {
      "enabled": true,
      "trace": true,
      "promptPolicy": true,
      "writeContextSnapshot": true,
      "writePrompts": true,
      "maxPreviewChars": 1200,
      "capabilityProfile": {
        "planning": {
          "mode": "planned"
        },
        "review": {
          "mode": "planned"
        }
      },
      "planningGuidanceMode": "separate_model",
      "miniRunnerMaxTurns": 50,
      "miniRunnerToolAllowlist": [
        "read_context",
        "search_memory"
      ],
      "acceptance": {
        "semanticValidation": true
      }
    }
  }
}
